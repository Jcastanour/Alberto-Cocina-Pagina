# --- Admin ---------------------------------------------------------------
# Contraseña del panel /admin y clave para firmar el token. CAMBIAR en prod.
ADMIN_PASSWORD=cambia-esta-clave
SECRET_KEY=genera-un-valor-aleatorio-largo

# --- CORS ----------------------------------------------------------------
# Orígenes del frontend permitidos (coma-separados).
# Dev:  http://localhost:5173
# Prod: https://aycobras.pages.dev,https://aycobras.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Cloudflare R2 (dejar vacío para usar almacenamiento local en disco) -
# Si se llenan estas 4, la API guarda imágenes y projects.json en R2.
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# URL pública del bucket/dominio de R2 (sin slash final), ej:
#   https://pub-xxxxxxxx.r2.dev   o   https://cdn.aycobras.com
R2_PUBLIC_URL=

# --- Límites de subida (opcional) ----------------------------------------
MAX_IMAGE_MB=10
MAX_GALLERY=12
